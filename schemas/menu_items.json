      "preparationTimeMin": { "bsonType": "int", "minimum": 1 },
      "imageFileId": { "bsonType": ["objectId", "null"] },
      "salesCount": { "bsonType": "int", "minimum": 0 },
      "createdAt": { "bsonType": "date" },
